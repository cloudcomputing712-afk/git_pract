# Initialize a new local repository
git init

# Clone a project from a URL (like GitHub)
git clone <url>

# Stage a specific file for a commit
git add <file-name>

# Stage ALL changed files
git add .

# Save your staged changes with a descriptive message
git commit -m "Brief description of what you fixed/added"

# Save your current messy changes and clear the workspace
git stash

# List all your stashed changes
git stash list

# Bring your changes back and remove them from the "drawer"
git stash pop

# Apply a specific commit from another branch to your current one
git cherry-pick <commit-hash>

# Open an interface to edit the last 5 commits
git rebase -i HEAD~5

# Create a tag for the current commit
git tag -a v1.0 -m "Release version 1.0"

# Push your tags to the server
git push origin --tags
